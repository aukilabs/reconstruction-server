{
    "name": "Reconstruction Server Devcontainer",
    "remoteUser": "reconstruction-server",
    "build": {
        "dockerfile": "../docker/Dockerfile.dev"
    },
    "workspaceFolder": "/app",
    "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
    "customizations": {
        "vscode": {
            "extensions":[
                "golang.Go",
                "ms-python.python",
                "ms-python.debugpy"
            ]
        }
    },
    "appPort": [8080],
    "runArgs": [
        "--gpus", "all",
        "--shm-size", "512m"
    ],

    // Uncomment if you want display forward
    // "containerEnv": {
    //     "DISPLAY": "unix:0"
    // },
    "mounts": [
        // Modify this to your own data folder
        // "source=/path/to/data,target=/data,type=bind",

        // Uncomment if you want display forward
        // "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached"
    ],
    "postCreateCommand": [
        "cp /app/src/hloc_extras/lightglue.py /src/Hierarchical-Localization/hloc/matchers/",
        "cp /app/src/hloc_extras/superpoint.py /src/Hierarchical-Localization/hloc/extractors/",
        "cd /app",
        "pwd",
        "ls -la",
        ".devcontainer/build_golang_server.sh",
        "mkdir -p build",
        "(cd build && pwd && ls -la && cmake -DCMAKE_BUILD_TYPE=Release -DPYBIND11_FINDPYTHON=ON .. && make all)",
        "echo 'Done!'"
    ]
}