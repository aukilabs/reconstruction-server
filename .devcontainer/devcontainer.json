{
    "name": "Reconstruction Server Devcontainer",
    "remoteUser": "reconstruction-server",
    "build": {
        "dockerfile": "../docker/Dockerfile",
        "context": "../",
        "args": {
            "IS_DEVELOPMENT": "true"
        }
    },
    "workspaceFolder": "/app",
    "workspaceMount": "source=${localWorkspaceFolder},target=/app,type=bind",
    "customizations": {
        "vscode": {
            "extensions":[
                "golang.Go",
                "ms-python.python",
                "ms-python.debugpy",
                "rust-lang.rust-analyzer"
            ]
        }
    },
    "appPort": [8080],
    "runArgs": [
        "--gpus", "all",
        "--shm-size", "512m"
    ],

    // Uncomment if you want display forward
    // "containerEnv": {
    //     "DISPLAY": "unix:0"
    // },
    "mounts": [
        // Modify this to your own data folder
        // "source=/path/to/data,target=/data,type=bind",

        // Uncomment if you want display forward
        // "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached"
    ],
    "postCreateCommand": "sudo .devcontainer/build_server.sh && sudo chown -R reconstruction-server:reconstruction-server /app"
}