ARG BASE_IMAGE_REPO=ghcr.io/aukilabs/reconstruction-server-base
ARG BASE_IMAGE_TAG=latest
FROM ${BASE_IMAGE_REPO}:${BASE_IMAGE_TAG}

ARG USERNAME=reconstruction-server
ARG USER_UID=1000
ARG USER_GID=$USER_UID
ARG DEBIAN_FRONTEND=noninteractive

# Install only dev-specific tooling on top of the shared runtime base.
RUN apt-get update && apt-get install -y --no-install-recommends \
    sudo \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    groupadd --gid "$USER_GID" "$USERNAME"; \
    useradd --uid "$USER_UID" --gid "$USER_GID" -m "$USERNAME"; \
    echo "$USERNAME ALL=(root) NOPASSWD:ALL" > /etc/sudoers.d/$USERNAME; \
    chmod 0440 /etc/sudoers.d/$USERNAME

ENV RUSTUP_HOME=/home/${USERNAME}/.rustup
ENV CARGO_HOME=/home/${USERNAME}/.cargo
ENV PATH="${CARGO_HOME}/bin:${PATH}"

# More convenient compute node default for local development:
ENV GLOBAL_RUNNER_WORKSPACE_ROOT=/app
ENV LOCAL_RUNNER_WORKSPACE_ROOT=/app
ENV DISABLE_TASKS_CLEANUP=true
ENV LOG_FORMAT=text

RUN curl https://sh.rustup.rs -sSf | bash -s -- -y --profile minimal --default-toolchain stable \
    && chown -R "$USERNAME:$USERNAME" "$RUSTUP_HOME" "$CARGO_HOME"
RUN rustup component add rustfmt clippy

WORKDIR /app

ENTRYPOINT ["/bin/bash"]