# --- Required ---
# DMS base URL
DMS_BASE_URL=https://dms.dev.aukiverse.com

# Compute node capabilities (comma-separated if multiple)
NODE_CAPABILITIES="/reconstruction/local-and-global-refinement/v1"

# Fallback static identity used if SIWE auth (below) is not configured
NODE_IDENTITY=siwe:00000000-0000-0000-0000-000000000001

# --- Optional: DMS polling/heartbeat tuning ---
#HEARTBEAT_JITTER_MS=250
POLL_BACKOFF_MS_MIN=1000
POLL_BACKOFF_MS_MAX=30000

# --- Optional: DDS SIWE authentication (preferred) ---
# When both DDS_BASE_URL and SECP256K1_PRIVHEX are set, the node performs
# SIWE against DDS to obtain short-lived access tokens that DMS accepts.
#NODE_URL=https://node.example.com/
#DDS_BASE_URL=https://dds.example.com
#REG_SECRET=replace-with-shared-secret
#SECP256K1_PRIVHEX=0x<64-hex-characters>

# SIWE token manager (refresh) tuning
#TOKEN_SAFETY_RATIO=0.75
#TOKEN_REAUTH_MAX_RETRIES=3
#TOKEN_REAUTH_JITTER_MS=500

# Registration loop (optional)
#REGISTER_INTERVAL_SECS=30
#REGISTER_MAX_RETRY=5
#REQUEST_TIMEOUT_SECS=20
